{{> head}}
{{> header}}

<h1>{{formTitle}}</h1>

{{#errors}}
  <div class="alert error" role="alert">
    <ul>
      {{#.}}
        <li>{{.}}</li>
      {{/.}}
    </ul>
  </div>
{{/errors}}

<form method="post" action="{{action}}">
  <div class="field">
    <label for="title">Title</label>
    <input id="title" name="title" type="text" required value="{{course.title}}">
  </div>

  <div class="field">
    <label for="description">Description</label>
    <textarea id="description" name="description" rows="4">{{course.description}}</textarea>
  </div>

  <div class="field">
    <label for="location">Location</label>
    <input id="location" name="location" type="text" required value="{{course.location}}">
  </div>

  <div class="field">
    <label for="price">Price (£)</label>
    <input id="price" name="price" type="number" min="0" step="0.01" required value="{{course.price}}">
  </div>

  <div class="field">
    <label for="level">Level</label>
    <select id="level" name="level" required>
      <option value="beginner" {{#course.levelBeginner}}selected{{/course.levelBeginner}}>Beginner</option>
      <option value="intermediate" {{#course.levelIntermediate}}selected{{/course.levelIntermediate}}>Intermediate</option>
      <option value="advanced" {{#course.levelAdvanced}}selected{{/course.levelAdvanced}}>Advanced</option>
    </select>
  </div>

  <div class="field">
    <label for="type">Type</label>
    <select id="type" name="type" required>
      <option value="WEEKLY_BLOCK" {{#course.typeWeekly}}selected{{/course.typeWeekly}}>Weekly Block</option>
      <option value="WEEKEND_WORKSHOP" {{#course.typeWorkshop}}selected{{/course.typeWorkshop}}>Weekend Workshop</option>
    </select>
  </div>

  <div class="field">
    <label for="startDate">Start date</label>
    <input id="startDate" name="startDate" type="date" value="{{course.startDate}}">
  </div>

  <div class="field">
    <label for="endDate">End date</label>
    <input id="endDate" name="endDate" type="date" value="{{course.endDate}}">
  </div>

  <div class="field">
    <label for="allowDropIn">Allow drop-in</label>
    <select id="allowDropIn" name="allowDropIn">
      <option value="true" {{#course.dropInYes}}selected{{/course.dropInYes}}>Yes</option>
      <option value="false" {{#course.dropInNo}}selected{{/course.dropInNo}}>No</option>
    </select>
  </div>

  <button class="btn primary" type="submit">Save Course</button>
</form>

{{> footer}}