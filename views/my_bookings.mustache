{{> head}}
{{> header}}

<article>
  <h1>My Bookings</h1>

  {{#bookings}}
    <article class="card">
      <h2>{{title}}</h2>
      <p class="muted">Type: {{type}}</p>
      <p class="muted">Status: {{status}}</p>
      <p class="muted">When: {{when}}</p>
      <p class="muted">Booked on: {{createdAt}}</p>
      <p><a class="btn" href="/bookings/{{id}}">View booking</a></p>
    </article>
  {{/bookings}}

  {{^bookings}}
    <p>You have no bookings yet.</p>
  {{/bookings}}
</article>

{{> footer}}